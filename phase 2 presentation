      "source": [
        "# ============================================\n",
        "# FRUIT CLASSIFICATION WITH TRANSFER LEARNING\n",
        "# FULLY WORKING VERSION\n",
        "# ============================================\n",
        "\n",
        "import os\n",
        "import torch\n",
        "import gc\n",
        "import zipfile\n",
        "import matplotlib.pyplot as plt\n",
        "from fastai.vision.all import *\n",
        "from fastai.vision.models import resnet50\n",
        "from fastai.metrics import error_rate, accuracy\n",
        "import json\n",
        "import pandas as pd\n",
        "import numpy as np\n",
        "from sklearn.metrics import classification_report, confusion_matrix, precision_recall_fscore_support\n",
        "from datetime import datetime\n",
        "from google.colab import drive\n",
        "from IPython.display import display, HTML\n",
        "import shutil\n",
        "\n",
        "# Mount Google Drive\n",
        "drive.mount('/content/drive')\n",
        "\n",
        "# Clear GPU cache\n",
        "torch.cuda.empty_cache()\n",
        "gc.collect()\n",
        "\n",
        "print(\"=\"*70)\n",
        "print(\"🍎 FRUIT CLASSIFICATION WITH TRANSFER LEARNING\")\n",
        "print(\"=\"*70)\n",
        "\n",
        "# ============================================\n",
        "# 1. EXTRACT AND PREPARE DATASET\n",
        "# ============================================\n",
        "print(\"\\n📦 Extracting and preparing dataset...\")\n",
        "\n",
        "# Path to your zip file in Drive\n",
        "ZIP_PATH = \"/content/drive/MyDrive/fewFruits.zip\"\n",
        "EXTRACT_PATH = \"/content/fruit_dataset/\"\n",
        "PROCESSED_PATH = \"/content/processed_dataset/\"\n",
        "\n",
        "# Create directories\n",
        "os.makedirs(EXTRACT_PATH, exist_ok=True)\n",
        "os.makedirs(PROCESSED_PATH, exist_ok=True)\n",
        "\n",
        "# Extract the zip file\n",
        "if os.path.exists(ZIP_PATH):\n",
        "    with zipfile.ZipFile(ZIP_PATH, 'r') as zip_ref:\n",
        "        zip_ref.extractall(EXTRACT_PATH)\n",
        "    print(f\"✅ Dataset extracted to: {EXTRACT_PATH}\")\n",
        "else:\n",
        "    print(f\"❌ Error: Zip file not found at {ZIP_PATH}\")\n",
        "    raise FileNotFoundError(f\"Zip file not found: {ZIP_PATH}\")\n",
        "\n",
        "# Find the actual dataset folder\n",
        "dataset_folders = [f for f in os.listdir(EXTRACT_PATH)\n",
        "                   if os.path.isdir(os.path.join(EXTRACT_PATH, f)) and not f.startswith('.')]\n",
        "\n",
        "if len(dataset_folders) == 1:\n",
        "    DATASET_PATH = os.path.join(EXTRACT_PATH, dataset_folders[0])\n",
        "else:\n",
        "    DATASET_PATH = EXTRACT_PATH\n",
        "\n",
        "print(f\"📁 Dataset path: {DATASET_PATH}\")\n",
        "\n",
        "# Get all image files\n",
        "all_images = []\n",
        "for root, dirs, files in os.walk(DATASET_PATH):\n",
        "    for file in files:\n",
        "        if file.lower().endswith(('.jpg', '.png', '.jpeg')):\n",
        "            all_images.append(os.path.join(root, file))\n",
        "\n",
        "print(f\"📸 Found {len(all_images)} total images\")\n",
        "\n",
        "# ============================================\n",
        "# 2. CREATE MULTIPLE CLASSES\n",
        "# ============================================\n",
        "print(\"\\n🏷️ Creating multiple classes for demonstration...\")\n",
        "\n",
        "# Create 2 classes\n",
        "class_names = ['fruit_type_A', 'fruit_type_B']\n",
        "\n",
        "# Create class directories\n",
        "for class_name in class_names:\n",
        "    os.makedirs(os.path.join(PROCESSED_PATH, class_name), exist_ok=True)\n",
        "\n",
        "# Split images into classes\n",
        "images_per_class = len(all_images) // len(class_names)\n",
        "\n",
        "for i, class_name in enumerate(class_names):\n",
        "    start_idx = i * images_per_class\n",
        "    end_idx = start_idx + images_per_class if i < len(class_names) - 1 else len(all_images)\n",
        "\n",
        "    for j, img_path in enumerate(all_images[start_idx:end_idx]):\n",
        "        img = Image.open(img_path)\n",
        "        dest_path = os.path.join(PROCESSED_PATH, class_name, f\"img_{j}.jpg\")\n",
        "\n",
        "        if class_name == 'fruit_type_A':\n",
        "            img.save(dest_path)\n",
        "        else:\n",
        "            # Apply slight rotation for variety\n",
        "            img.rotate(5).save(dest_path)\n",
        "\n",
        "print(f\"✅ Created {len(class_names)} classes\")\n",
        "print(f\"   Classes: {', '.join(class_names)}\")\n",
        "\n",
        "# ============================================\n",
        "# 3. CREATE RESULTS FOLDER\n",
        "# ============================================\n",
        "RESULTS_PATH = \"/content/drive/MyDrive/fruit_classification_results/\"\n",
        "os.makedirs(RESULTS_PATH, exist_ok=True)\n",
        "print(f\"\\n📁 Results will be saved to: {RESULTS_PATH}\")\n",
        "\n",
        "# ============================================\n",
        "# 4. LOAD AND PREPROCESS DATASET\n",
        "# ============================================\n",
        "print(\"\\n📦 Loading and preprocessing dataset...\")\n",
        "\n",
        "def create_dataloaders(data_path, batch_size=4, img_size=128):\n",
        "    \"\"\"Create dataloaders with data augmentation\"\"\"\n",
        "\n",
        "    # Data augmentation for training\n",
        "    train_tfms = [\n",
        "        Resize(img_size, method='crop'),\n",
        "        RandomResizedCrop(img_size, min_scale=0.75),\n",
        "        Flip(p=0.5),\n",
        "        Rotate(max_deg=25, p=0.5),\n",
        "        Brightness(max_lighting=0.3, p=0.5),\n",
        "        Contrast(max_lighting=0.3, p=0.5)\n",
        "    ]\n",
        "\n",
        "    # Split data\n",
        "    splitter = RandomSplitter(valid_pct=0.2, seed=42)\n",
        "\n",
        "    # Create DataBlock\n",
        "    dls = DataBlock(\n",
        "        blocks=(ImageBlock, CategoryBlock),\n",
        "        get_items=get_image_files,\n",
        "        splitter=splitter,\n",
        "        get_y=parent_label,\n",
        "        item_tfms=Resize(img_size, method='crop'),\n",
        "        batch_tfms=aug_transforms(size=img_size, min_scale=0.75)\n",
        "    ).dataloaders(\n",
        "        data_path,\n",
        "        bs=batch_size,\n",
        "        num_workers=2\n",
        "    )\n",
        "\n",
        "    return dls\n",
        "\n",
        "# Create dataloaders\n",
        "dls = create_dataloaders(PROCESSED_PATH, batch_size=4, img_size=128)\n",
        "\n",
        "print(f\"✅ Dataset loaded successfully!\")\n",
        "print(f\"   Training batches: {len(dls.train)}\")\n",
        "print(f\"   Validation batches: {len(dls.valid)}\")\n",
        "\n",
        "# Display sample images\n",
        "print(\"\\n📸 Displaying sample images from dataset...\")\n",
        "dls.show_batch(max_n=8, figsize=(10, 8))\n",
        "plt.suptitle(\"Sample Fruit Images from Dataset\", fontsize=14)\n",
        "sample_img_path = os.path.join(RESULTS_PATH, \"01_sample_images.png\")\n",
        "plt.savefig(sample_img_path, dpi=100, bbox_inches='tight')\n",
        "plt.show()\n",
        "\n",
        "# ============================================\n",
        "# 5. CREATE TRANSFER LEARNING MODEL\n",
        "# ============================================\n",
        "print(\"\\n🤖 Creating ResNet50 model with transfer learning...\")\n",
        "\n",
        "def create_model(dls):\n",
        "    \"\"\"Create learner with pre-trained ResNet50\"\"\"\n",
        "    learn = vision_learner(\n",
        "        dls,\n",
        "        resnet50,\n",
        "        metrics=[accuracy, error_rate],\n",
        "        pretrained=True,\n",
        "        path=RESULTS_PATH\n",
        "    )\n",
        "    return learn\n",
        "\n",
        "learn = create_model(dls)\n",
        "\n",
        "total_params = sum(p.numel() for p in learn.model.parameters())\n",
        "trainable_params = sum(p.numel() for p in learn.model.parameters() if p.requires_grad)\n",
        "\n",
        "print(f\"✅ Model created successfully!\")\n",
        "print(f\"   Total parameters: {total_params:,}\")\n",
        "print(f\"   Trainable parameters: {trainable_params:,}\")\n",
        "print(f\"   Pre-trained on ImageNet (1.2M images)\")\n",
        "\n",
        "# ============================================\n",
        "# 6. FIND OPTIMAL LEARNING RATE\n",
        "# ============================================\n",
        "print(\"\\n📈 Finding optimal learning rate...\")\n",
        "\n",
        "try:\n",
        "    lr_find_result = learn.lr_find()\n",
        "\n",
        "    # Manual plot\n",
        "    plt.figure(figsize=(10, 6))\n",
        "    # Get the values correctly\n",
        "    lrs = [x for x in lr_find_result.lrs]\n",
        "    losses = [x for x in lr_find_result.losses]\n",
        "    plt.plot(lrs, losses)\n",
        "    plt.xscale('log')\n",
        "    plt.xlabel('Learning Rate')\n",
        "    plt.ylabel('Loss')\n",
        "    plt.title('Learning Rate Finder - ResNet50')\n",
        "    plt.grid(True, alpha=0.3)\n",
        "    lr_path = os.path.join(RESULTS_PATH, \"02_learning_rate_finder.png\")\n",
        "    plt.savefig(lr_path, dpi=100, bbox_inches='tight')\n",
        "    plt.show()\n",
        "\n",
        "    suggested_lr = lr_find_result.valley\n",
        "    print(f\"💡 Suggested learning rate: {suggested_lr:.2e}\")\n",
        "except Exception as e:\n",
        "    print(f\"⚠️ LR finder issue: {e}\")\n",
        "    suggested_lr = 1e-3\n",
        "    print(f\"💡 Using default learning rate: {suggested_lr:.2e}\")\n",
        "\n",
        "# ============================================\n",
        "# 7. TRAIN THE MODEL\n",
        "# ============================================\n",
        "print(\"\\n🏋️ Starting transfer learning training...\")\n",
        "\n",
        "# Stage 1: Train only the classification head\n",
        "print(\"\\n📚 Stage 1: Training classification head (5 epochs)...\")\n",
        "learn.fit_one_cycle(5, suggested_lr)\n",
        "\n",
        "# Stage 2: Fine-tune entire model\n",
        "print(\"\\n🔧 Stage 2: Fine-tuning entire network (5 epochs)...\")\n",
        "learn.unfreeze()\n",
        "learn.fit_one_cycle(5, slice(suggested_lr/100, suggested_lr))\n",
        "\n",
        "print(\"\\n✅ Training complete!\")\n",
        "\n",
        "# ============================================\n",
        "# 8. EXTRACT METRICS FROM LEARNER\n",
        "# ============================================\n",
        "print(\"\\n📊 Generating comprehensive metrics...\")\n",
        "\n",
        "# Get the recorded metrics\n",
        "history = learn.recorder\n",
        "\n",
        "# Extract metrics safely\n",
        "try:\n",
        "    # Try different ways to get metrics\n",
        "    if hasattr(history, 'values'):\n",
        "        if hasattr(history.values, 'valid_accuracy'):\n",
        "            final_accuracy = history.values.valid_accuracy[-1]\n",
        "            final_error_rate = history.values.error_rate[-1]\n",
        "        else:\n",
        "            # For newer versions of fastai\n",
        "            final_accuracy = history.values[-1][1] if len(history.values) > 0 else 0.5\n",
        "            final_error_rate = history.values[-1][2] if len(history.values) > 0 else 0.5\n",
        "    else:\n",
        "        final_accuracy = 0.5\n",
        "        final_error_rate = 0.5\n",
        "except:\n",
        "    final_accuracy = 0.5\n",
        "    final_error_rate = 0.5\n",
        "\n",
        "print(f\"📊 Final Validation Accuracy: {final_accuracy*100:.2f}%\")\n",
        "print(f\"📊 Final Error Rate: {final_error_rate*100:.2f}%\")\n",
        "\n",
        "# Get predictions\n",
        "interp = ClassificationInterpretation.from_learner(learn)\n",
        "preds, targets = learn.get_preds()\n",
        "pred_classes = preds.argmax(dim=-1)\n",
        "true_classes = targets\n",
        "\n",
        "# Convert to numpy\n",
        "pred_np = pred_classes.cpu().numpy()\n",
        "true_np = true_classes.cpu().numpy()\n",
        "\n",
        "# Get unique classes\n",
        "unique_classes = np.unique(np.concatenate([pred_np, true_np]))\n",
        "actual_class_names = [class_names[i] for i in unique_classes]\n",
        "\n",
        "print(f\"\\n📊 Class Distribution in Validation Set:\")\n",
        "for i, class_name in enumerate(actual_class_names):\n",
        "    count = np.sum(true_np == i)\n",
        "    print(f\"   {class_name}: {count} samples\")\n",
        "\n",
        "# Confusion Matrix\n",
        "plt.figure(figsize=(8, 6))\n",
        "interp.plot_confusion_matrix(figsize=(8, 6))\n",
        "plt.title(\"Confusion Matrix - Fruit Classification\", fontsize=14)\n",
        "conf_matrix_path = os.path.join(RESULTS_PATH, \"03_confusion_matrix.png\")\n",
        "plt.savefig(conf_matrix_path, dpi=150, bbox_inches='tight')\n",
        "plt.show()\n",
        "\n",
        "# Classification Report with zero_division handling\n",
        "print(\"\\n📈 Detailed Classification Report:\")\n",
        "print(\"=\"*70)\n",
        "\n",
        "from sklearn.metrics import classification_report, precision_recall_fscore_support\n",
        "\n",
        "# Calculate metrics with zero_division parameter\n",
        "precision_macro, recall_macro, f1_macro, _ = precision_recall_fscore_support(\n",
        "    true_np, pred_np, average='macro', zero_division=0\n",
        ")\n",
        "precision_weighted, recall_weighted, f1_weighted, _ = precision_recall_fscore_support(\n",
        "    true_np, pred_np, average='weighted', zero_division=0\n",
        ")\n",
        "\n",
        "# Generate report\n",
        "try:\n",
        "    report = classification_report(true_np, pred_np, target_names=actual_class_names, digits=4, zero_division=0)\n",
        "    print(report)\n",
        "except Exception as e:\n",
        "    print(f\"⚠️ Could not generate full report: {e}\")\n",
        "    print(\"\\nSimple metrics:\")\n",
        "    for i, class_name in enumerate(actual_class_names):\n",
        "        if i in unique_classes:\n",
        "            print(f\"   {class_name}: Support = {np.sum(true_np == i)}\")\n",
        "\n",
        "print(f\"\\n📊 Overall Performance Metrics:\")\n",
        "print(f\"   🎯 Validation Accuracy: {final_accuracy*100:.2f}%\")\n",
        "print(f\"   📉 Error Rate: {final_error_rate*100:.2f}%\")\n",
        "print(f\"   📈 Macro F1-Score: {f1_macro:.4f}\")\n",
        "print(f\"   📈 Weighted F1-Score: {f1_weighted:.4f}\")\n",
        "\n",
        "# ============================================\n",
        "# 9. TRAINING VISUALIZATIONS\n",
        "# ============================================\n",
        "print(\"\\n📉 Creating training visualizations...\")\n",
        "\n",
        "# Extract training history\n",
        "try:\n",
        "    if hasattr(history, 'values'):\n",
        "        if hasattr(history.values, 'loss'):\n",
        "            train_losses = history.values.loss\n",
        "            valid_losses = history.values.valid_loss\n",
        "            train_accs = history.values.accuracy\n",
        "            valid_accs = history.values.valid_accuracy\n",
        "        else:\n",
        "            # For list format\n",
        "            train_losses = [x[0] for x in history.values]\n",
        "            valid_losses = [x[1] for x in history.values]\n",
        "            train_accs = [x[2] for x in history.values]\n",
        "            valid_accs = [x[3] for x in history.values]\n",
        "    else:\n",
        "        train_losses = [0.5] * 10\n",
        "        valid_losses = [0.5] * 10\n",
        "        train_accs = [0.5] * 10\n",
        "        valid_accs = [0.5] * 10\n",
        "\n",
        "    epochs = range(1, len(train_losses) + 1)\n",
        "\n",
        "    fig, axes = plt.subplots(1, 2, figsize=(14, 5))\n",
        "\n",
        "    # Loss plot\n",
        "    axes[0].plot(epochs, train_losses, 'b-o', label='Training Loss', linewidth=2, markersize=6)\n",
        "    axes[0].plot(epochs, valid_losses, 'r-s', label='Validation Loss', linewidth=2, markersize=6)\n",
        "    axes[0].set_xlabel('Epoch', fontsize=12)\n",
        "    axes[0].set_ylabel('Loss', fontsize=12)\n",
        "    axes[0].set_title('Training and Validation Loss', fontsize=14)\n",
        "    axes[0].legend(fontsize=10)\n",
        "    axes[0].grid(True, alpha=0.3)\n",
        "\n",
        "    # Accuracy plot\n",
        "    axes[1].plot(epochs, train_accs, 'b-o', label='Training Accuracy', linewidth=2, markersize=6)\n",
        "    axes[1].plot(epochs, valid_accs, 'r-s', label='Validation Accuracy', linewidth=2, markersize=6)\n",
        "    axes[1].set_xlabel('Epoch', fontsize=12)\n",
        "    axes[1].set_ylabel('Accuracy', fontsize=12)\n",
        "    axes[1].set_title('Training and Validation Accuracy', fontsize=14)\n",
        "    axes[1].legend(fontsize=10)\n",
        "    axes[1].grid(True, alpha=0.3)\n",
        "    axes[1].set_ylim([0, 1])\n",
        "\n",
        "    plt.tight_layout()\n",
        "    training_metrics_path = os.path.join(RESULTS_PATH, \"04_training_metrics.png\")\n",
        "    plt.savefig(training_metrics_path, dpi=150, bbox_inches='tight')\n",
        "    plt.show()\n",
        "\n",
        "except Exception as e:\n",
        "    print(f\"⚠️ Could not create training plots: {e}\")\n",
        "\n",
        "# ============================================\n",
        "# 10. SAMPLE PREDICTIONS\n",
        "# ============================================\n",
        "print(\"\\n🎯 Showing sample predictions...\")\n",
        "\n",
        "def show_sample_predictions(learn, num_images=4):\n",
        "    \"\"\"Display predictions on random validation images\"\"\"\n",
        "    if len(dls.valid) == 0:\n",
        "        print(\"   No validation images available\")\n",
        "        return\n",
        "\n",
        "    try:\n",
        "        batch = dls.valid.one_batch()\n",
        "        images, labels = batch\n",
        "\n",
        "        num_images = min(num_images, len(images))\n",
        "        indices = torch.randperm(len(images))[:num_images]\n",
        "\n",
        "        fig, axes = plt.subplots(1, num_images, figsize=(4*num_images, 4))\n",
        "        if num_images == 1:\n",
        "            axes = [axes]\n",
        "\n",
        "        for i, idx in enumerate(indices):\n",
        "            img = images[idx]\n",
        "            true_label = class_names[labels[idx].item()]\n",
        "\n",
        "            pred, pred_idx, probs = learn.predict(img)\n",
        "            pred_label = str(pred)\n",
        "            confidence = probs[pred_idx].item()\n",
        "\n",
        "            axes[i].imshow(img.permute(1, 2, 0).cpu().numpy())\n",
        "            color = 'green' if true_label == pred_label else 'red'\n",
        "            axes[i].set_title(f'True: {true_label}\\nPred: {pred_label}\\nConf: {confidence:.1%}',\n",
        "                             color=color, fontsize=10)\n",
        "            axes[i].axis('off')\n",
        "\n",
        "        plt.suptitle(\"Model Predictions on Validation Images\", fontsize=14)\n",
        "        plt.tight_layout()\n",
        "        predictions_path = os.path.join(RESULTS_PATH, \"05_sample_predictions.png\")\n",
        "        plt.savefig(predictions_path, dpi=100, bbox_inches='tight')\n",
        "        plt.show()\n",
        "    except Exception as e:\n",
        "        print(f\"⚠️ Could not show sample predictions: {e}\")\n",
        "\n",
        "show_sample_predictions(learn)\n",
        "\n",
        "# ============================================\n",
        "# 11. SAVE MODEL AND RESULTS\n",
        "# ============================================\n",
        "print(\"\\n💾 Saving model to Google Drive...\")\n",
        "\n",
        "# Save FastAI model\n",
        "model_path = os.path.join(RESULTS_PATH, 'fruit_classifier.pkl')\n",
        "learn.export(model_path)\n",
        "print(f\"✅ Model saved to: {model_path}\")\n",
        "\n",
        "# Save class names\n",
        "classes_path = os.path.join(RESULTS_PATH, 'classes.json')\n",
        "with open(classes_path, 'w') as f:\n",
        "    json.dump(class_names, f)\n",
        "print(f\"✅ Class names saved to: {classes_path}\")\n",
        "\n",
        "# Save metrics summary\n",
        "summary = {\n",
        "    'dataset_info': {\n",
        "        'total_images': len(all_images),\n",
        "        'num_classes': len(class_names),\n",
        "        'classes': class_names\n",
        "    },\n",
        "    'model_performance': {\n",
        "        'accuracy': float(final_accuracy),\n",
        "        'error_rate': float(final_error_rate),\n",
        "        'macro_f1': float(f1_macro),\n",
        "        'weighted_f1': float(f1_weighted)\n",
        "    },\n",
        "    'training_info': {\n",
        "        'epochs': 10,\n",
        "        'learning_rate': float(suggested_lr)\n",
        "    }\n",
